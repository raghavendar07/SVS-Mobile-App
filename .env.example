# SVS Driver — runtime config (Vite exposes only VITE_* vars to the client)
VITE_API_BASE_URL=https://api.svs.example.com
VITE_API_TIMEOUT_MS=15000

# Firebase Cloud Messaging
VITE_FCM_API_KEY=
VITE_FCM_PROJECT_ID=
VITE_FCM_SENDER_ID=
VITE_FCM_APP_ID=
VITE_FCM_VAPID_KEY=

# GPS tracking
VITE_GPS_TRACK_INTERVAL_MS=30000

# Tenant
VITE_DEFAULT_TENANT_ID=
